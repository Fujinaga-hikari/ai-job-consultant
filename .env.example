# === Database (Vercel Postgres / Neon) ===
aiconsul_DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# === Google Gemini ===
GEMINI_API_KEY="your-gemini-api-key"

# === Brevo (Email) ===
BREVO_API_KEY="xkeysib-xxxxxxxxxxxx"

# Sender address (must be verified in Brevo)
EMAIL_FROM="noreply@yourdomain.com"

# Internal notification recipient (comma-separated)
NOTIFY_EMAIL="admin@yourdomain.com"

# Weekly report recipient (optional — defaults to NOTIFY_EMAIL)
WEEKLY_REPORT_EMAIL="admin@yourdomain.com"

# SEO blog (manual trigger via admin UI only — no cron)
# Minimum pending keywords when using "fill queue" (default: 10)
ARTICLE_MIN_QUEUE_SIZE="10"
# Keywords per AI suggestion batch (default: 5)
ARTICLE_AUTO_SUGGEST_COUNT="5"
# Max articles per admin bulk session (UI default: 15)
ARTICLE_ADMIN_MAX_GENERATE="15"

# === Weekly report cron (Vercel Cron) ===
# Generate: openssl rand -hex 32
CRON_SECRET="your-random-cron-secret"

# === Basic Auth (optional — remove or leave empty to disable) ===
BASIC_AUTH_USER=""
BASIC_AUTH_PASS=""

# === Geo Restriction (optional — comma-separated ISO country codes, empty = allow all) ===
# Example: "JP" = Japan only, "JP,US" = Japan + US
ALLOWED_COUNTRIES="JP"

# === Site URL (used for OGP canonical URL) ===
NEXT_PUBLIC_SITE_URL="https://your-domain.com"

# === Admin Dashboard Auth ===
ADMIN_USER="admin"
ADMIN_PASS="your-strong-password"
# ランダムな文字列（例: openssl rand -hex 32）
ADMIN_TOKEN="your-random-secret-token"
