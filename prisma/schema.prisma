generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model GenerationLog {
  id            String          @id @default(cuid())
  companyName   String
  jobTitle      String
  salary        String?
  location      String?
  content       String
  persona       String?
  result        String
  createdAt     DateTime        @default(now())
  consultations Consultation[]
}

model RateLimit {
  id        String   @id @default(cuid())
  ip        String
  date      String   // YYYY-MM-DD
  count     Int      @default(1)
  lastRequest DateTime @default(now())
  createdAt DateTime @default(now())

  @@unique([ip, date])
  @@index([ip, date])
}

model PageView {
  id        String   @id @default(cuid())
  path      String   @default("/") // "/" = LP, "/blog/slug" = 記事
  date      String   // YYYY-MM-DD JST
  visitorId String   // SHA-256(IP + UA) — anonymous UU identifier
  createdAt DateTime @default(now())

  @@index([date])
  @@index([date, visitorId])
  @@index([path])
}

model CtaClick {
  id        String   @id @default(cuid())
  slug      String   // 記事スラッグ
  date      String   // YYYY-MM-DD JST
  visitorId String
  createdAt DateTime @default(now())

  @@index([slug])
  @@index([date])
}

model Article {
  id              String   @id @default(cuid())
  slug            String   @unique
  keyword         String
  title           String
  metaDescription String
  content         String
  coverImage      String?
  imagePool       String?  // JSON: PexelsPhoto[]
  publishedAt     DateTime @default(now())
  createdAt       DateTime @default(now())

  @@index([publishedAt])
}

model ArticleKeyword {
  id        String               @id @default(cuid())
  slug      String               @unique
  keyword   String
  titleHint String
  source    ArticleKeywordSource @default(AI)
  status    ArticleKeywordStatus @default(PENDING)
  error     String?
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@index([status])
  @@index([createdAt])
}

enum ArticleKeywordSource {
  SEED
  AI
  MANUAL
}

enum ArticleKeywordStatus {
  PENDING
  GENERATED
  FAILED
}

model Consultation {
  id              String         @id @default(cuid())
  email           String
  name            String?
  companyName     String?
  phone           String?
  preferredTime   String?
  generationLogId String?
  generationLog   GenerationLog? @relation(fields: [generationLogId], references: [id])
  createdAt       DateTime       @default(now())
}
