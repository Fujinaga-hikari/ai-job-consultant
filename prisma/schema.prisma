generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model GenerationLog {
  id            String          @id @default(cuid())
  companyName   String
  jobTitle      String
  salary        String?
  location      String?
  content       String
  persona       String?
  result        String
  createdAt     DateTime        @default(now())
  consultations Consultation[]
}

model RateLimit {
  id        String   @id @default(cuid())
  ip        String
  date      String   // YYYY-MM-DD
  count     Int      @default(1)
  lastRequest DateTime @default(now())
  createdAt DateTime @default(now())

  @@unique([ip, date])
  @@index([ip, date])
}

model Consultation {
  id              String         @id @default(cuid())
  email           String
  name            String?
  companyName     String?
  preferredTime   String?
  generationLogId String?
  generationLog   GenerationLog? @relation(fields: [generationLogId], references: [id])
  createdAt       DateTime       @default(now())
}
